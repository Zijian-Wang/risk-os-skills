# NewsAPI (optional — news skipped if not set)
NEWSAPI_KEY=

# Schwab API — required for US market OHLCV data
# Get credentials from https://developer.schwab.com after registering your app
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=
SCHWAB_REFRESH_TOKEN=

# Local proxy (optional — used if Schwab/news APIs are geo-blocked)
HTTPS_PROXY=socks5://127.0.0.1:1082
HTTP_PROXY=socks5://127.0.0.1:1082
