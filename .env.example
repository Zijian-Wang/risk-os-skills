# NewsAPI (optional — news skipped if not set)
NEWSAPI_KEY=

# Firebase Admin SDK (required for fetch_account.py)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# The Firebase Auth UID to query positions under
FIREBASE_USER_UID=

# Schwab API Configuration
# Get these from https://developer.schwab.com after registering your app
# Note: VITE_ prefix exposes the variable to the frontend (client ID only - safe to expose)
# Must match the Schwab app callback URL exactly (same value as SCHWAB_REDIRECT_URI)
VITE_SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# For local development URI
VITE_SCHWAB_REDIRECT_URI=http://localhost:5173/auth/schwab/callback
SCHWAB_REDIRECT_URI=http://localhost:5173/auth/schwab/callback

# Production URI
VITE_SCHWAB_REDIRECT_URI=https://risk-os.app/auth/schwab/callback
SCHWAB_REDIRECT_URI=https://risk-os.app/auth/schwab/callback

# Schwab Token Encryption Key production Environment
SCHWAB_TOKEN_ENCRYPTION_KEY=

#STOOQ
STOOQ_API_KEY=
# Local SOCKS5 proxy (used by fetch_data.py for Schwab/news APIs)
HTTPS_PROXY=socks5://127.0.0.1:1082
HTTP_PROXY=socks5://127.0.0.1:1082
